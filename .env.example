# Copy to .env and fill in values. Never commit .env.

# API key sent by clients in the x-api-key header (must match evaluator)
API_KEY=

# Gemini (primary). Optional GEMINI_API_KEY_2 … _5 for rotation.
GEMINI_API_KEY=
GEMINI_ANALYST_MODEL=gemini-2.5-flash
GEMINI_PERSONA_MODEL=gemini-2.5-flash
GEMINI_TRANSLATOR_MODEL=gemini-2.5-flash
GEMINI_EXTRACTOR_MODEL=gemini-2.0-flash

# Groq (fallback when Gemini fails)
GROQ_API_KEY=
GROQ_ANALYST_MODEL=llama-3.3-70b-versatile
GROQ_PERSONA_MODEL=llama-3.3-70b-versatile

# Optional Postgres on Railway, etc. Leave unset for local sqlite:///./honeypot.db
DATABASE_URL=

# GUVI / platform callbacks (defaults in config.py if unset)
GUVI_CALLBACK_URL_1=
GUVI_CALLBACK_URL_2=

# Timeouts and conversation limits
LLM_TIMEOUT_SECONDS=15
CALLBACK_TIMEOUT_SECONDS=5
MAX_TURNS=10
ESTIMATED_SECONDS_PER_TURN=20

HONEYPOT_CONFIDENCE_THRESHOLD=0.5
LEGIT_CONFIDENCE_THRESHOLD=0.8
